# EmailJS credentials for the Contact form.
# Copy this file to .env.local and fill in the real values from
# https://dashboard.emailjs.com/admin
#
# In the EmailJS dashboard, lock the Public Key to your production
# domain(s) under Account → Security → Allowlist.

VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
